# =============================================================================
# AI Brand Agent — Ubuntu / systemd environment (production / staging)
# =============================================================================
# Copy to e.g. /etc/ai-brand-agent.env, chmod 600, owner deploy user.
# systemd: EnvironmentFile=/etc/ai-brand-agent.env
#
# Values below mirror what this repo uses in config/config.exs and dev DB shape.
# **Rotate every secret before a public or production deployment.** Do not commit a
# filled copy of this file if your repository is public.
#
# Resolution: brand_<KEY> → BRAND_<KEY> → <KEY> (see lib/ai_brand_agent/config/env.ex)
# =============================================================================

# --- Process / HTTP (shared host: keep brand_* so PORT does not clash) ---
brand_PHX_SERVER=true
brand_PORT=4001

# --- Phoenix (production) ---
# Generate for prod: mix phx.gen.secret
brand_SECRET_KEY_BASE=REPLACE_WITH_mix_phx_gen_secret
# Public hostname when TLS terminates at nginx/caddy (not localhost in real prod)
brand_PHX_HOST=localhost
# Browser-visible URL for routes / Auth0 redirect_uri (default: https://PHX_HOST:443).
# UAT over http://SERVER_IP:PORT before a domain, e.g. port 4002:
#   brand_PHX_HOST=203.0.113.10
#   brand_PORT=4002
#   brand_PHX_PUBLIC_SCHEME=http
# Omit brand_PHX_PUBLIC_PORT to reuse brand_PORT for link generation.
# brand_PHX_PUBLIC_SCHEME=https
# brand_PHX_PUBLIC_PORT=443
# Same DB user/password/host pattern as config/dev.exs; change DB name for prod:
brand_DATABASE_URL=ecto://postgres:P%40ssw0rd@127.0.0.1/ai_brand_agent_prod
brand_POOL_SIZE=10
brand_ECTO_IPV6=false
# brand_DNS_CLUSTER_QUERY=

# --- Auth0 (from config/config.exs :auth0) ---
brand_AUTH0_DOMAIN=dev-677l58koldj2zef6.us.auth0.com
brand_AUTH0_CLIENT_ID=YhMo6wJk3vrdzj4q1FVvgFbjydr7zQPg
brand_AUTH0_CLIENT_SECRET=CAhNLwh-GF4SdgpXV_zPw_K8Nxc0l9JIy6Iqg2SDc_bKegT6msevlkkC_HXKjuT-
brand_AUTH0_AUDIENCE=https://dev-677l58koldj2zef6.us.auth0.com/api/v2/

# Optional overrides (defaults in config/config.exs if unset)
brand_AUTH0_FACEBOOK_CONNECTION_SCOPE=pages_show_list,pages_manage_posts
brand_AUTH0_LINKEDIN_CONNECTION_SCOPE=openid profile email w_member_social
brand_AUTH0_FACEBOOK_CONNECTION_NAME=facebook
brand_AUTH0_MY_ACCOUNT_SCOPE=openid profile offline_access create:me:connected_accounts read:me:connected_accounts delete:me:connected_accounts

# Token Vault — set ONE of (PEM string often too long for a single line; prefer _PATH on server):
# brand_AUTH0_TOKEN_VAULT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----..."
brand_AUTH0_TOKEN_VAULT_PRIVATE_KEY_PATH=/opt/ai_brand_agent/priv/auth0_token_vault.key

# Optional: encrypt Auth0 refresh tokens at rest (openssl rand -base64 32)
# brand_AUTH0_REFRESH_TOKEN_ENCRYPTION_KEY=

# --- Gemini (from config/config.exs :gemini api_key / model) ---
brand_GEMINI_API_KEY=AIzaSyDNt4Qj4lV6OZBCt9Qr25WfEk-ZkOmHEEA
brand_GEMINI_MODEL=gemini-2.5-flash
