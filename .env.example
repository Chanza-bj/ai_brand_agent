# =============================================================================
# AI Brand Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Load with: source .env  (or use direnv / .envrc)
# =============================================================================

# ── Auth0 ────────────────────────────────────────────────────────────────────
# Create an application at https://manage.auth0.com
# Enable Token Vault and Connected Accounts for LinkedIn/Facebook
# Add grant type: urn:auth0:params:oauth:grant-type:token-exchange:federated-connection-access-token
# Configure Token Vault Privileged Access with your RSA public key
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
AUTH0_AUDIENCE=https://your-tenant.us.auth0.com/api/v2/

# Optional: comma-separated Meta permissions for “Connect Facebook” (Auth0 connection_scope).
# Meta rejects space-separated lists (“Invalid Scope … delimiter”). Example:
# AUTH0_FACEBOOK_CONNECTION_SCOPE=pages_show_list,pages_manage_posts,pages_read_engagement

# Optional: space-separated LinkedIn OAuth scopes for “Connect LinkedIn” (Auth0 connection_scope).
# Must include w_member_social for posting. Example:
# AUTH0_LINKEDIN_CONNECTION_SCOPE="openid profile email w_member_social"

# Optional: Auth0 Social connection *name* for Facebook (default "facebook"). Set this if you
# created a new Facebook connection (e.g. facebook-pages) to drop legacy scopes like manage_pages.
# AUTH0_FACEBOOK_CONNECTION_NAME=facebook-pages

# Token Vault (Privileged Worker) - one of:
# AUTH0_TOKEN_VAULT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----..."
# AUTH0_TOKEN_VAULT_PRIVATE_KEY_PATH=path/to/private_key.pem

# Optional: override My Account API scope string for Connected Accounts setup (default in config/config.exs).
# AUTH0_MY_ACCOUNT_SCOPE="openid profile offline_access create:me:connected_accounts read:me:connected_accounts delete:me:connected_accounts"

# ── Gemini API ───────────────────────────────────────────────────────────────
# Get an API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# ── Database ─────────────────────────────────────────────────────────────────
# Only required for production (dev/test use config/*.exs defaults)
# DATABASE_URL=ecto://postgres:postgres@localhost/ai_brand_agent_prod

# ── Phoenix ──────────────────────────────────────────────────────────────────
# Only required for production
# SECRET_KEY_BASE=generate_with_mix_phx_gen_secret
# PHX_HOST=yourdomain.com
# PORT=4000
# PHX_SERVER=true
