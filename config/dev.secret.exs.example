import Config

# Copy this file to `config/dev.secret.exs` (gitignored) and fill in real values.
# That file overrides `config.exs` placeholders for `mix phx.server` when env vars are not set.
#
# Alternatively, set AUTH0_DOMAIN, AUTH0_CLIENT_ID, AUTH0_CLIENT_SECRET, AUTH0_AUDIENCE (optional),
# and GEMINI_API_KEY in the environment; `config/runtime.exs` merges them at app startup.

config :ai_brand_agent, :auth0,
  domain: "your-tenant.auth0.com",
  client_id: "your-auth0-application-client-id",
  client_secret: "your-auth0-application-client-secret",
  audience: "https://your-tenant.auth0.com/api/v2/"

config :ai_brand_agent, :gemini,
  api_key: "your-gemini-api-key"
